# Port du serveur Express
PORT=5000

# Origin autorisée pour CORS (l'app React en dev)
CLIENT_ORIGIN=http://localhost:5173

# Clé API Resend (https://resend.com) pour l'envoi d'email du formulaire de
# contact. Tant qu'elle n'est pas renseignée, le serveur se contente de
# logguer les messages reçus dans la console (utile en dev local).
RESEND_API_KEY=

# Adresse qui reçoit les messages du formulaire de contact
CONTACT_TO_EMAIL=stevedjen.s@gmail.com
