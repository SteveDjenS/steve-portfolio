# Port du serveur Express
PORT=5000

# Origin autorisée pour CORS (l'app React en dev)
CLIENT_ORIGIN=http://localhost:5173

# Configuration SMTP pour l'envoi d'email du formulaire de contact.
# Tant que ces variables ne sont pas renseignées, le serveur se contente
# de logguer les messages reçus dans la console (utile en dev local).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Adresse qui reçoit les messages du formulaire de contact
CONTACT_TO_EMAIL=stevedjen.s@gmail.com
